// karuku (mathcheck) - Prisma schema
// DB: SQLite(ローカル・簡易運用向け)
// 実行: npx prisma migrate dev --name add_analysis_record

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  accounts      Account[]
  sessions      Session[]

  // ホーム画面フロー(問題画像×解答画像の解析)の履歴。今回追加。
  analyses      AnalysisRecord[]

  // 旧/chat機能用(現在は本流では未使用。ファイルを壊さないためスキーマは残置)
  conversations Conversation[]
  questions     QuestionHistory[]

  createdAt     DateTime  @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── ホーム画面フロー(本流)用 ─────────────────────────
// 「問題画像 × 解答画像」を解析した結果の履歴(学習履歴・質問履歴)
model AnalysisRecord {
  id        String   @id @default(cuid())
  userId    String
  status    String   // "correct" | "incorrect" | "partial"
  mistake   String?
  hint      String
  flowchart String   // JSON文字列としてstring[]を保存
  steps     String   // JSON文字列としてStepDetail[]を保存
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── 旧/chat機能用(現在未使用。参照エラー防止のため残置) ──
model Conversation {
  id        String    @id @default(cuid())
  userId    String
  title     String    @default("新しい会話")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           String
  content        String
  hasImage       Boolean      @default(false)
  isError        Boolean      @default(false)
  createdAt      DateTime     @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model QuestionHistory {
  id           String   @id @default(cuid())
  userId       String
  question     String
  topic        String?
  isCorrect    Boolean?
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
